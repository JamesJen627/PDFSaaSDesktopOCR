{
  "name": "@pdfsaas/electron",
  "version": "0.1.0",
  "private": true,
  "description": "PDFSaaS OCR Desktop — Electron shell (Phase 0 scaffold)",
  "main": "dist/main/index.js",
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build:main": "tsc -p tsconfig.main.json",
    "build:preload": "tsc -p tsconfig.preload.json",
    "build": "npm run build:main && npm run build:preload",
    "test": "npm run build:main && node --test dist/main/appPaths.test.js"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "typescript": "^6.0.3"
  }
}
