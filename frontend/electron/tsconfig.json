{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "ignoreDeprecations": "6.0",
    "noEmit": true,
    "rootDir": ".",
    "types": ["node"]
  },
  "include": ["shared/**/*.ts", "main/**/*.ts", "preload/**/*.ts"],
}
